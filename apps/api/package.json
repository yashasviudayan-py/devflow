{
  "name": "@devflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "pnpm --filter @devflow/shared build && tsx watch src/index.ts",
    "build": "pnpm --filter @devflow/shared build && tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "pnpm --filter @devflow/shared build && vitest run",
    "typecheck": "pnpm --filter @devflow/shared build && tsc --noEmit"
  },
  "dependencies": {
    "@devflow/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "@types/supertest": "^7.2.0",
    "eslint": "^8.57.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
