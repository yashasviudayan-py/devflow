# ===========================================================================
# DevFlow environment variables
#
# Local setup:   cp .env.example .env   (then adjust values as needed)
# NEVER commit a real .env. Set production values in the Render / Vercel / Neon
# dashboards, not in git. See docs/deployment.md for production guidance.
# ===========================================================================

# --- Shared ---
# One of: development | test | production
NODE_ENV="development"

# --- Backend (apps/api) ---
# PostgreSQL connection string. The local default matches docker-compose.yml.
# In production this is your Neon connection string (use the POOLED URL for the
# running app — see DIRECT_URL below and docs/deployment.md).
DATABASE_URL="postgresql://devflow_user:devflow_password@localhost:5432/devflow?schema=public"

# Optional: a direct (non-pooled) Neon connection string used only for running
# Prisma migrations. Leave unset locally. Only needed if you point DATABASE_URL
# at Neon's pooled (pgBouncer) endpoint. See docs/deployment.md.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/devflow?sslmode=require"

# Secret used to sign auth JWTs. Use a long, random value. In production it must
# be at least 16 chars and must not be this placeholder.
JWT_SECRET="replace-this-with-a-long-random-secret-before-using-auth"

# Local API port. In production the platform (Render) injects PORT, which the
# server prefers automatically — do not hardcode PORT on Render.
API_PORT=4000

# Frontend origin allowed by the CORS allowlist (credentialed requests).
# In production set this to your Vercel URL, e.g. https://devflowx.vercel.app
WEB_URL="http://localhost:3000"

# Optional log verbosity: error | warn | info (default: info).
# LOG_LEVEL="info"

# --- Frontend (apps/web) ---
# The absolute origin of the backend API.
# - Local: the API origin itself (http://localhost:4000). The browser calls it
#   directly; the auth cookie works with SameSite=Lax over same-site localhost.
# - Production (Vercel): set this to the real backend URL, e.g.
#   https://devflow-1wg5.onrender.com. In production the browser does NOT use this
#   value directly — it calls the API same-origin at "/api", and the Next.js
#   rewrite (apps/web/next.config.mjs) proxies "/api/*" to this URL. That keeps
#   the auth cookie FIRST-PARTY and avoids browsers blocking it as a cross-site /
#   third-party cookie (Safari, Chrome incognito). See docs/deployment.md.
#   Do NOT set this to "/api" — the rewrite needs the absolute backend origin.
# NOTE: Next.js only reads env files from apps/web. For local overrides, put this
# in apps/web/.env.local (see docs/local-development.md).
NEXT_PUBLIC_API_URL="http://localhost:4000"
